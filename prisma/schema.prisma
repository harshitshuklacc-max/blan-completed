generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ADMIN
}

enum ProductStatus {
  ACTIVE
  DISABLED
  DRAFT
}

enum Gender {
  MEN
  WOMEN
  UNISEX
  KIDS
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  UPI
  CARD
  NET_BANKING
  COD
  CASH
  POS
}

enum SaleChannel {
  ONLINE
  OFFLINE_POS
}

enum InventoryChangeType {
  ONLINE_SALE
  OFFLINE_SALE
  MANUAL_UPDATE
  BUSY_IMPORT
  RETURN
  CANCELLATION
  ADJUSTMENT
  RESTOCK
}

enum BarcodeType {
  CODE128
  EAN13
  QR
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum NotificationType {
  ORDER
  PAYMENT
  INVENTORY
  SYSTEM
  PROMOTION
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  FACTORY_RESET
}

// ─── ADMIN & AUTH ──────────────────────────────────────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  email        String?  @unique
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions         Session[]
  auditLogs        AuditLog[]
  busyImportLogs   BusyImportLog[]
  inventoryLogs    InventoryLog[]

  @@map("admins")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(CUSTOMER)
  isActive     Boolean  @default(true) @map("is_active")
  emailVerified Boolean @default(false) @map("email_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer      Customer?
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@index([email])
  @@map("users")
}

model Customer {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  firstName String   @map("first_name")
  lastName  String?  @map("last_name")
  phone     String?
  avatar    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]
  reviews    Review[]
  wishlists  Wishlist[]
  addresses  Address[]
  carts      Cart[]
  returns    Return[]

  @@index([phone])
  @@map("customers")
}

model Session {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  adminId   String?  @map("admin_id")
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin Admin? @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

// ─── CATALOG ───────────────────────────────────────────────────────────────────

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  logo        String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("brands")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  parentId    String?  @map("parent_id")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId])
  @@map("categories")
}

model Product {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  description    String?
  brandId        String?       @map("brand_id")
  categoryId     String?       @map("category_id")
  gender         Gender        @default(UNISEX)
  size           String?
  color          String?
  purchasePrice  Decimal       @default(0) @map("purchase_price") @db.Decimal(12, 2)
  sellingPrice   Decimal       @map("selling_price") @db.Decimal(12, 2)
  discount       Decimal       @default(0) @db.Decimal(5, 2)
  mrp            Decimal       @db.Decimal(12, 2)
  sku            String        @unique
  status         ProductStatus @default(ACTIVE)
  isFeatured     Boolean       @default(false) @map("is_featured")
  isTrending     Boolean       @default(false) @map("is_trending")
  isNewArrival   Boolean       @default(false) @map("is_new_arrival")
  isBestSeller   Boolean       @default(false) @map("is_best_seller")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  brand        Brand?         @relation(fields: [brandId], references: [id])
  category     Category?      @relation(fields: [categoryId], references: [id])
  images       ProductImage[]
  inventory    Inventory?
  barcodes     Barcode[]
  orderItems   OrderItem[]
  invoiceItems InvoiceItem[]
  reviews      Review[]
  wishlists    Wishlist[]
  cartItems    CartItem[]

  @@index([brandId])
  @@index([categoryId])
  @@index([status])
  @@index([sku])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  url       String
  alt       String?
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Barcode {
  id        String      @id @default(cuid())
  productId String      @map("product_id")
  code      String      @unique
  type      BarcodeType @default(CODE128)
  isPrimary Boolean     @default(true) @map("is_primary")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([code])
  @@map("barcodes")
}

// ─── INVENTORY ─────────────────────────────────────────────────────────────────

model Inventory {
  id        String   @id @default(cuid())
  productId String   @unique @map("product_id")
  quantity  Int      @default(0)
  reserved  Int      @default(0)
  minStock  Int      @default(0) @map("min_stock")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

model InventoryLog {
  id          String              @id @default(cuid())
  productId   String              @map("product_id")
  adminId     String?             @map("admin_id")
  changeType  InventoryChangeType @map("change_type")
  quantityBefore Int              @map("quantity_before")
  quantityAfter  Int              @map("quantity_after")
  quantityChange Int              @map("quantity_change")
  reference   String?
  notes       String?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  admin Admin? @relation(fields: [adminId], references: [id])

  @@index([productId])
  @@index([changeType])
  @@index([createdAt])
  @@map("inventory_logs")
}

model BusyImportLog {
  id           String   @id @default(cuid())
  adminId      String   @map("admin_id")
  fileName     String   @map("file_name")
  addedCount   Int      @default(0) @map("added_count")
  updatedCount Int      @default(0) @map("updated_count")
  failedCount  Int      @default(0) @map("failed_count")
  errors       Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  admin Admin @relation(fields: [adminId], references: [id])

  @@index([createdAt])
  @@map("busy_import_logs")
}

// ─── ORDERS & PAYMENTS ─────────────────────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @map("order_number")
  customerId      String?       @map("customer_id")
  status          OrderStatus   @default(PENDING)
  channel         SaleChannel   @default(ONLINE)
  subtotal        Decimal       @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(12, 2)
  tax             Decimal       @default(0) @db.Decimal(12, 2)
  shipping        Decimal       @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal       @map("grand_total") @db.Decimal(12, 2)
  couponCode      String?       @map("coupon_code")
  couponDiscount  Decimal       @default(0) @map("coupon_discount") @db.Decimal(12, 2)
  paymentMethod   PaymentMethod? @map("payment_method")
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  shippingAddress Json?         @map("shipping_address")
  billingAddress  Json?         @map("billing_address")
  notes           String?
  trackingNumber  String?       @map("tracking_number")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  customer   Customer?   @relation(fields: [customerId], references: [id])
  items      OrderItem[]
  payments   Payment[]
  invoices   Invoice[]
  returns    Return[]

  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  name      String
  sku       String
  barcode   String?
  quantity  Int
  price     Decimal  @db.Decimal(12, 2)
  discount  Decimal  @default(0) @db.Decimal(12, 2)
  tax       Decimal  @default(0) @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @map("order_id")
  amount          Decimal       @db.Decimal(12, 2)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  razorpayOrderId String?       @map("razorpay_order_id")
  razorpayPaymentId String?     @map("razorpay_payment_id")
  razorpaySignature String?     @map("razorpay_signature")
  failureReason   String?       @map("failure_reason")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  order Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  logs  PaymentLog[]

  @@index([orderId])
  @@index([razorpayOrderId])
  @@map("payments")
}

model PaymentLog {
  id        String   @id @default(cuid())
  paymentId String   @map("payment_id")
  event     String
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_logs")
}

// ─── INVOICES ──────────────────────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique @map("invoice_number")
  orderId       String?       @map("order_id")
  channel       SaleChannel   @default(ONLINE)
  customerName  String?       @map("customer_name")
  customerPhone String?       @map("customer_phone")
  storeName     String        @map("store_name")
  storeAddress  String        @map("store_address")
  storePhone    String        @map("store_phone")
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  grandTotal    Decimal       @map("grand_total") @db.Decimal(12, 2)
  paymentMethod PaymentMethod @map("payment_method")
  invoiceDate   DateTime      @map("invoice_date")
  expiresAt     DateTime?     @map("expires_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  order Order?        @relation(fields: [orderId], references: [id])
  items InvoiceItem[]

  @@index([invoiceNumber])
  @@index([invoiceDate])
  @@index([expiresAt])
  @@map("invoices")
}

model InvoiceItem {
  id        String   @id @default(cuid())
  invoiceId String   @map("invoice_id")
  productId String?  @map("product_id")
  name      String
  sku       String
  barcode   String?
  quantity  Int
  price     Decimal  @db.Decimal(12, 2)
  discount  Decimal  @default(0) @db.Decimal(12, 2)
  tax       Decimal  @default(0) @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

// ─── CUSTOMER FEATURES ─────────────────────────────────────────────────────────

model Cart {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    CartItem[]

  @@index([customerId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String   @map("cart_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Wishlist {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("wishlists")
}

model Address {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  label      String   @default("Home")
  fullName   String   @map("full_name")
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  country    String   @default("India")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("addresses")
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String?
  discountType  String    @map("discount_type")
  discountValue Decimal   @map("discount_value") @db.Decimal(12, 2)
  minOrderValue Decimal?  @map("min_order_value") @db.Decimal(12, 2)
  maxDiscount   Decimal?  @map("max_discount") @db.Decimal(12, 2)
  usageLimit    Int?      @map("usage_limit")
  usedCount     Int       @default(0) @map("used_count")
  isActive      Boolean   @default(true) @map("is_active")
  startsAt      DateTime? @map("starts_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([code])
  @@map("coupons")
}

model Review {
  id         String       @id @default(cuid())
  productId  String       @map("product_id")
  customerId String       @map("customer_id")
  orderId    String?      @map("order_id")
  rating     Int
  title      String?
  comment    String?
  images     Json?
  isVerified Boolean      @default(false) @map("is_verified")
  status     ReviewStatus @default(PENDING)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([customerId])
  @@index([status])
  @@map("reviews")
}

// ─── RETURNS & REFUNDS ─────────────────────────────────────────────────────────

model Return {
  id        String       @id @default(cuid())
  orderId   String       @map("order_id")
  customerId String      @map("customer_id")
  reason    String
  status    ReturnStatus @default(REQUESTED)
  notes     String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  order    Order    @relation(fields: [orderId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  refunds  Refund[]

  @@index([orderId])
  @@index([status])
  @@map("returns")
}

model Refund {
  id        String       @id @default(cuid())
  returnId  String       @map("return_id")
  amount    Decimal      @db.Decimal(12, 2)
  status    RefundStatus @default(PENDING)
  method    PaymentMethod?
  reference String?
  notes     String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  return Return @relation(fields: [returnId], references: [id])

  @@index([returnId])
  @@map("refunds")
}

// ─── HOMEPAGE & SETTINGS ───────────────────────────────────────────────────────

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  group     String   @default("general")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@map("settings")
}

model HomepageSetting {
  id        String   @id @default(cuid())
  section   String   @unique
  title     String?
  subtitle  String?
  content   Json?
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("homepage_settings")
}

model HeroBanner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  image     String
  link      String?
  ctaText   String?  @map("cta_text")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("hero_banners")
}

// ─── ANALYTICS & LOGS ──────────────────────────────────────────────────────────

model Analytics {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  revenue   Decimal  @default(0) @db.Decimal(14, 2)
  orders    Int      @default(0)
  onlineSales  Int   @default(0) @map("online_sales")
  offlineSales Int   @default(0) @map("offline_sales")
  customers Int      @default(0)
  productsSold Int   @default(0) @map("products_sold")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([date])
  @@index([date])
  @@map("analytics")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?     @map("user_id")
  adminId   String?     @map("admin_id")
  action    AuditAction
  entity    String
  entityId  String?     @map("entity_id")
  details   Json?
  ipAddress String?     @map("ip_address")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user  User?  @relation(fields: [userId], references: [id])
  admin Admin? @relation(fields: [adminId], references: [id])

  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}
